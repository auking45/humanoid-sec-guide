{
  "server": {
    "ip": "192.168.1.100",
    "admin_user": "ubuntu"
  },
  "users": ["dev-alice", "dev-bob"],
  "security": {
    "firewall": {
      "enabled": true,
      "allow_ports": ["80", "443", "8080", "9090/tcp"]
    },
    "harden_services": {
      "enabled": true,
      "disable": [
        "x11vnc",
        "tightvncserver",
        "vncserver-x11-serviced",
        "xrdp",
        "nfs-server",
        "smbd",
        "nmbd",
        "vsftpd",
        "proftpd",
        "pure-ftpd",
        "apache2",
        "nginx",
        "lighttpd"
      ]
    },
    "auditd": {
      "enabled": true
    },
    "usb_hardening": {
      "block_storage": true
    }
  }
}
